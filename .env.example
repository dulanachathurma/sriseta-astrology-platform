# Base URL used by the frontend to call the serverless API during local dev.
# Leave empty in production on Vercel - relative /api routes are used automatically.
VITE_API_BASE_URL=

# Optional: override the source article the weekly horoscope scraper reads from.
HOROSCOPE_SOURCE_URL=https://www.divaina.lk/nakatha/84589

# Optional: how long (seconds) the serverless function caches scraped results.
HOROSCOPE_CACHE_SECONDS=3600
